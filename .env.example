DATABASE_URL=postgresql://user:password@localhost:5432/db_name?sslmode=disable
# Optional locally; use a direct Neon URL for Prisma CLI in production.
DIRECT_URL=
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-unique-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-unique-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:3000,http://localhost:3000
MAX_UPLOAD_SIZE_BYTES=5242880
# Required only for the protected Vercel Cron endpoint.
CRON_SECRET=
SYNC_SCHEDULER_ENABLED=false
SYNC_SCHEDULER_INTERVAL_MS=86400000
