DATABASE_URL=postgresql://user:password@localhost:5432/db_name?sslmode=disable
PORT=3000
NODE_ENV=development
JWT_SECRET=replace-with-a-long-unique-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-unique-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_BYTES=5242880
SYNC_SCHEDULER_ENABLED=false
SYNC_SCHEDULER_INTERVAL_MS=86400000
