generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  password     String
  name         String?
  role         Role    @default(USER)
  refreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum DataStatus {
  ACTIVE
  ARCHIVED
}

model Source {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  code        String  @unique
  description String?
  website     String?

  resources   SourceResource[]
  medications Medication[]
  syncJobs    SyncJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model SourceResource {
  id          Int       @id @default(autoincrement())
  name        String
  url         String?
  fileHash    String?
  publishedAt DateTime?

  sourceId Int
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  syncJobs SyncJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
}

model OfficialDocument {
  id          Int       @id @default(autoincrement())
  title       String
  reference   String?   @unique
  url         String?
  publishedAt DateTime?

  reimbursements Reimbursement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Regime {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  code        String  @unique
  description String?

  reimbursements Reimbursement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManagingOrganization {
  id      Int     @id @default(autoincrement())
  code    String  @unique
  name    String
  website String?
  phone   String?

  reimbursements Reimbursement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
}

model Manufacturer {
  id      Int     @id @default(autoincrement())
  name    String  @unique
  country String?

  medications Medication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Category {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?

  medications Medication[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model ActiveIngredient {
  id   Int    @id @default(autoincrement())
  name String @unique

  medications MedicationIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Medication {
  id           Int        @id @default(autoincrement())
  code         String?    @unique // Code d'enregistrement / AMM
  name         String
  form         String? // Ex: Comprimé, Sirop
  presentation String? // Ex: Boîte de 30
  dosageUnit   String?
  isGeneric    Boolean    @default(false)
  status       DataStatus @default(ACTIVE)

  manufacturerId Int?
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id], onDelete: SetNull)

  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sourceId Int?
  source   Source? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  prices         MedicationPrice[]
  reimbursements Reimbursement[]
  ingredients    MedicationIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([manufacturerId])
  @@index([categoryId])
  @@index([sourceId])
}

model MedicationPrice {
  id            Int       @id @default(autoincrement())
  publicPrice   Float? // PPV (Prix Public de Vente)
  hospitalPrice Float? // PHG (Prix Hôpital)
  effectiveDate DateTime?

  medicationId Int
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([medicationId])
}

model MedicationIngredient {
  id     Int     @id @default(autoincrement())
  dosage String? // Ex: 500mg, 1g

  medicationId Int
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  activeIngredientId Int
  activeIngredient   ActiveIngredient @relation(fields: [activeIngredientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([medicationId, activeIngredientId])
  @@index([medicationId])
  @@index([activeIngredientId])
}

model Reimbursement {
  id                Int        @id @default(autoincrement())
  reimbursementBase Float?
  reimbursementRate Float?
  referencePrice    Float?
  conditions        String?
  status            DataStatus @default(ACTIVE)

  medicationId Int
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  organizationId Int
  organization   ManagingOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  regimeId Int?
  regime   Regime? @relation(fields: [regimeId], references: [id], onDelete: SetNull)

  documentId Int?
  document   OfficialDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([medicationId, organizationId])
  @@index([medicationId])
  @@index([organizationId])
  @@index([regimeId])
}

model SyncJob {
  id                Int     @id @default(autoincrement())
  status            String // AVAILABLE, UNAVAILABLE, OUTDATED, INVALID_FORMAT, SOURCE_CHANGED, SOURCE_NOT_AUTOMATABLE, SYNC_SUCCESS, SYNC_PARTIAL, SYNC_FAILED
  recordsRead       Int     @default(0)
  recordsValid      Int     @default(0)
  recordsRejected   Int     @default(0)
  recordsCreated    Int     @default(0)
  recordsUpdated    Int     @default(0)
  recordsDuplicates Int     @default(0)
  errorsCount       Int     @default(0)
  errorDetails      String? // JSON ou détails textuels

  sourceId Int
  source   Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  resourceId Int?
  resource   SourceResource? @relation(fields: [resourceId], references: [id], onDelete: SetNull)

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sourceId])
  @@index([startedAt])
}
